{
  "version": 2,
  "name": "grapplers2",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/canvas", "destination": "/Grapplers.html" },
    { "source": "/app", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "/grapplers/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }] }
  ]
}
